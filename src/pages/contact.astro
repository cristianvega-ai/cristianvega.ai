---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Cristian Vega — consulting on applied AI, collaborations, or building something together."
  active="contact"
>
  <main>
    <section class="section section--tight page-head dotgrid">
      <div class="wrap">
        <p class="marker"><span class="marker__sig">§</span> Contact</p>
        <h1 class="page-title">Let's <span class="hl">build</span> something.</h1>
        <p class="page-lede">
          Best for consulting on applied AI, collaborations, or comparing notes on shipping AI in production. I read everything.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="wrap wrap--narrow">
        <a class="btn btn--signal btn--lg" href="mailto:hello@cristianvega.ai">hello@cristianvega.ai</a>
        <div class="contact-links">
          <a href="mailto:hello@cristianvega.ai"><span class="k">Email</span> hello@cristianvega.ai</a>
          <a href="https://www.linkedin.com/in/cristianvega-ai" rel="me noopener noreferrer" target="_blank"><span class="k">LinkedIn</span> /in/cristianvega-ai</a>
          <a href="https://github.com/cristianvega-ai" rel="me noopener noreferrer" target="_blank"><span class="k">GitHub</span> @cristianvega-ai</a>
          <a href="/rss.xml"><span class="k">RSS</span> cristianvega.ai/rss.xml</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
