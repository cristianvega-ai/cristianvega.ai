---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { formatMachineDate, formatReadableDate } from "../lib/posts";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description} active="writing">
  <main>
    <article class="section section--tight">
      <div class="wrap wrap--narrow">
        <header class="article__head">
          <p class="article__cat">
            <span class="marker__sig">§</span>
            {post.data.category}
          </p>
          <h1 class="article__title">{post.data.title}</h1>
          <div class="article__meta">
            <time datetime={formatMachineDate(post.data.date)}>{formatReadableDate(post.data.date)}</time>
            <span class="sep">/</span>
            <span class="by">Cristian Vega</span>
            {
              post.data.tags.length > 0 && (
                <>
                  <span class="sep">/</span>
                  <span>{post.data.tags.join(" · ")}</span>
                </>
              )
            }
          </div>
        </header>

        <div class="prose">
          <slot />
        </div>
      </div>
    </article>
  </main>
</BaseLayout>
