---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  active?: "home" | "writing" | "projects" | "about" | "contact";
  bare?: boolean;
}

const {
  title = "Cristian Vega — Senior Director, AI Engineering",
  description = "Head of AI R&D at Patra Corporation. Engineering leader building production AI for insurance, from NLP models to agentic autonomous workflows.",
  active = "home",
  bare = false
} = Astro.props;

const pageTitle = title.includes("Cristian Vega") ? title : `${title} — Cristian Vega`;
const siteOrigin = Astro.site ?? new URL("https://cristianvega.ai");
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL("/images/cristian-vega.png", siteOrigin).toString();
const ogImageAlt = "Portrait of Cristian Vega";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="alternate" type="application/rss+xml" title="Cristian Vega Writing" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Schibsted+Grotesk:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%2315171A'/%3E%3Cg transform='rotate(-24 16 16)'%3E%3Cellipse cx='16' cy='16' rx='12' ry='5' fill='none' stroke='%238b9184' stroke-width='2'/%3E%3Ccircle cx='28' cy='16' r='3' fill='%23C8331F'/%3E%3C/g%3E%3Ccircle cx='16' cy='16' r='3.6' fill='%23F3F4EE'/%3E%3C/svg%3E"
    />
    <ClientRouter />
  </head>
  <body data-page={active}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/" aria-label="Cristian Vega home">
          <span class="brand__mark">
            <svg viewBox="0 0 32 32" aria-hidden="true">
              <g transform="rotate(-24 16 16)">
                <ellipse cx="16" cy="16" rx="12.5" ry="5.2" fill="none" stroke="#8b9184" stroke-width="1.6"></ellipse>
                <circle cx="28.5" cy="16" r="2.5" fill="#C8331F"></circle>
              </g>
              <circle cx="16" cy="16" r="3.3" fill="#F3F4EE"></circle>
            </svg>
          </span>
          <span>Cristian Vega</span>
        </a>

        <nav class="nav" aria-label="Primary">
          <a
            class:list={["nav__link", active === "projects" && "nav__link--active"]}
            href="/projects/"
            aria-current={active === "projects" ? "page" : undefined}>projects</a
          >
          <a
            class:list={["nav__link", active === "writing" && "nav__link--active"]}
            href="/writing/"
            aria-current={active === "writing" ? "page" : undefined}>writing</a
          >
          <a
            class:list={["nav__link", active === "about" && "nav__link--active"]}
            href="/about/"
            aria-current={active === "about" ? "page" : undefined}>about</a
          >
          <a
            class:list={["nav__link", active === "contact" && "nav__link--active"]}
            href="/contact/"
            aria-current={active === "contact" ? "page" : undefined}>contact</a
          >
        </nav>
      </div>
    </header>

    <div id="main-content">
      <slot />
    </div>

    {
      !bare && (
        <footer class="site-footer">
          <div class="wrap site-footer__inner">
            <span class="site-footer__left"><span class="dot"></span> © 2026 · open to talks</span>
            <div class="social">
              <a href="/writing/">writing</a>
              <a href="/rss.xml">rss</a>
              <a href="/sitemap-index.xml">sitemap</a>
            </div>
          </div>
        </footer>
      )
    }
  </body>
</html>
